## Configurazione credenziali DB — Copia in db_config.yaml e inserisci i valori reali
## ATTENZIONE: db_config.yaml è in .gitignore e NON deve essere committato

params:
  user: 'INSERIRE_UTENTE'
  password: 'INSERIRE_PASSWORD'
  host: 'INSERIRE_HOST'
  port: 1521
  service_name: 'INSERIRE_SERVICE_NAME'
  array_size: 100000
  chunk_size: 500000
  output_path: "./data/01.FROM_DB/"
  sales_path: "./data/01.FROM_DB/VENDITE"

tabelle:
